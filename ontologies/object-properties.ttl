# @prefix : <https://cyberterrain.org/ns/object-properties#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix stone: <https://cyberterrain.org/ns/stone#> .

<https://cyberterrain.org/ns/object-properties#> rdf:type owl:Ontology ;
    rdfs:comment "STIX 2.1 object properties for the STONE ontology. Identifier-typed STIX properties become ObjectProperties linking directly to named individuals by IRI. Vocabulary and enumeration references link to the individuals defined in vocabularies.ttl." .


#################################################################
#    Common Reference Properties — all / most STIX Objects
#################################################################

###  https://cyberterrain.org/ns/stone#createdByRef
stone:createdByRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the Identity SDO that created this STIX object. (STIX: created_by_ref)" ;
    rdfs:range stone:Identity .


###  https://cyberterrain.org/ns/stone#objectMarkingRefs
stone:objectMarkingRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to MarkingDefinition objects that apply data-handling markings to this entire object. (STIX: object_marking_refs)" ;
    rdfs:range stone:MarkingDefinitionObject .


###  https://cyberterrain.org/ns/stone#granularMarkings
stone:granularMarkings rdf:type owl:ObjectProperty ;
    rdfs:comment "Property-level data-handling markings targeting specific fields of this object. (STIX: granular_markings)" ;
    rdfs:range stone:GranularMarking .


###  https://cyberterrain.org/ns/stone#externalReferences
stone:externalReferences rdf:type owl:ObjectProperty ;
    rdfs:comment "References to non-STIX information sources such as CVEs, ATT&CK techniques, or URLs. (STIX: external_references)" ;
    rdfs:range stone:ExternalReference .


#################################################################
#    Sub-Object: GranularMarking
#################################################################

###  https://cyberterrain.org/ns/stone#markingRef
stone:markingRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the MarkingDefinition applied by this granular marking entry. (STIX: granular-marking.marking_ref)" ;
    rdfs:domain stone:GranularMarking ;
    rdfs:range stone:MarkingDefinitionObject .


#################################################################
#    Sub-Object: HashEntry
#    The hashes dictionary in STIX maps algorithm names to hex values.
#    Each entry is reified as a stone:HashEntry individual with
#    stone:algorithm (ObjectProperty) and stone:hashValue (DatatypeProperty).
#################################################################

###  https://cyberterrain.org/ns/stone#hashes
stone:hashes rdf:type owl:ObjectProperty ;
    rdfs:comment "Cryptographic hashes of an artifact, file, certificate, or other content, expressed as a set of HashEntry individuals. (STIX: hashes)" ;
    rdfs:range stone:HashEntry .


###  https://cyberterrain.org/ns/stone#algorithm
stone:algorithm rdf:type owl:ObjectProperty ;
    rdfs:comment "The hashing algorithm used for this hash entry (hashing-algorithm-ov). (STIX: hashes dictionary key)" ;
    rdfs:domain stone:HashEntry ;
    rdfs:range stone:HashingAlgorithmVocabulary .


#################################################################
#    Common: kill chain phases
#################################################################

###  https://cyberterrain.org/ns/stone#killChainPhases
stone:killChainPhases rdf:type owl:ObjectProperty ;
    rdfs:comment "Kill chain phase(s) associated with this attack-pattern, indicator, infrastructure, malware, or tool. (STIX: kill_chain_phases)" ;
    rdfs:range stone:KillChainPhase .


#################################################################
#    SDO: grouping
#################################################################

###  https://cyberterrain.org/ns/stone#context
stone:context rdf:type owl:ObjectProperty ;
    rdfs:comment "Shared context that motivates this grouping (grouping-context-ov). (STIX: context)" ;
    rdfs:domain stone:Grouping ;
    rdfs:range stone:GroupingContextVocabulary .


###  https://cyberterrain.org/ns/stone#objectRefs
stone:objectRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to STIX objects included in or annotated by this grouping, report, note, opinion, or observed-data. For observed-data the referenced objects MUST be SCOs. (STIX: object_refs)" ;
    rdfs:range stone:StixObject .


#################################################################
#    SDO: identity
#################################################################

###  https://cyberterrain.org/ns/stone#identityClass
stone:identityClass rdf:type owl:ObjectProperty ;
    rdfs:comment "Type of entity represented by this identity (identity-class-ov): individual, group, system, organization, class, unknown. (STIX: identity_class)" ;
    rdfs:domain stone:Identity ;
    rdfs:range stone:IdentityClassVocabulary .


###  https://cyberterrain.org/ns/stone#sectors
stone:sectors rdf:type owl:ObjectProperty ;
    rdfs:comment "Industry sectors this identity operates in (industry-sector-ov). Multiple values as multiple triples. (STIX: sectors)" ;
    rdfs:domain stone:Identity ;
    rdfs:range stone:IndustrySectorVocabulary .


#################################################################
#    SDO: indicator
#################################################################

###  https://cyberterrain.org/ns/stone#indicatorTypes
stone:indicatorTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "Categories of this indicator (indicator-type-ov): anomalous-activity, anonymization, benign, compromised, malicious-activity, attribution, unknown. (STIX: indicator_types)" ;
    rdfs:domain stone:Indicator ;
    rdfs:range stone:IndicatorTypeVocabulary .


###  https://cyberterrain.org/ns/stone#patternType
stone:patternType rdf:type owl:ObjectProperty ;
    rdfs:comment "Pattern language used by this indicator (pattern-type-ov): stix, pcre, sigma, snort, suricata, yara. (STIX: pattern_type)" ;
    rdfs:domain stone:Indicator ;
    rdfs:range stone:PatternTypeVocabulary .


#################################################################
#    SDO: infrastructure
#################################################################

###  https://cyberterrain.org/ns/stone#infrastructureTypes
stone:infrastructureTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "Functional categories of this infrastructure (infrastructure-type-ov). (STIX: infrastructure_types)" ;
    rdfs:domain stone:Infrastructure ;
    rdfs:range stone:InfrastuctureTypeVocabulary .


#################################################################
#    SDO: intrusion-set and threat-actor (shared)
#################################################################

###  https://cyberterrain.org/ns/stone#resourceLevel
stone:resourceLevel rdf:type owl:ObjectProperty ;
    rdfs:comment "Resource level available to this intrusion set or threat actor (attack-resource-level-ov): individual, club, contest, team, organization, government. (STIX: resource_level)" ;
    rdfs:range stone:AttackResourceLevelVocabulary .


###  https://cyberterrain.org/ns/stone#primaryMotivation
stone:primaryMotivation rdf:type owl:ObjectProperty ;
    rdfs:comment "Primary motivation driving this intrusion set or threat actor (attack-motivation-ov). (STIX: primary_motivation)" ;
    rdfs:range stone:AttackMotivationVocabulary .


###  https://cyberterrain.org/ns/stone#secondaryMotivations
stone:secondaryMotivations rdf:type owl:ObjectProperty ;
    rdfs:comment "Additional motivations beyond the primary motivation (attack-motivation-ov). Multiple values as multiple triples. (STIX: secondary_motivations)" ;
    rdfs:range stone:AttackMotivationVocabulary .


#################################################################
#    SDO: location
#################################################################

###  https://cyberterrain.org/ns/stone#region
stone:region rdf:type owl:ObjectProperty ;
    rdfs:comment "UN M.49 macro-geographical region (region-ov). (STIX: region)" ;
    rdfs:domain stone:Location ;
    rdfs:range stone:RegionVocabulary .


#################################################################
#    SDO: malware
#################################################################

###  https://cyberterrain.org/ns/stone#malwareTypes
stone:malwareTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "Functional categories of this malware (malware-type-ov). Multiple values as multiple triples. (STIX: malware_types)" ;
    rdfs:domain stone:Malware ;
    rdfs:range stone:MalwareTypeVocabulary .


###  https://cyberterrain.org/ns/stone#architectureExecutionEnvs
stone:architectureExecutionEnvs rdf:type owl:ObjectProperty ;
    rdfs:comment "Processor architectures this malware can execute on (processor-architecture-ov). Multiple values as multiple triples. (STIX: architecture_execution_envs)" ;
    rdfs:domain stone:Malware ;
    rdfs:range stone:ProcessorArchitectureVocabulary .


###  https://cyberterrain.org/ns/stone#implementationLanguages
stone:implementationLanguages rdf:type owl:ObjectProperty ;
    rdfs:comment "Programming languages used to implement this malware (implementation-language-ov). Multiple values as multiple triples. (STIX: implementation_languages)" ;
    rdfs:domain stone:Malware ;
    rdfs:range stone:ImplementationLanguageVocabulary .


###  https://cyberterrain.org/ns/stone#capabilities
stone:capabilities rdf:type owl:ObjectProperty ;
    rdfs:comment "Functional capabilities exhibited by this malware (malware-capabilities-ov). Multiple values as multiple triples. (STIX: capabilities)" ;
    rdfs:domain stone:Malware ;
    rdfs:range stone:MalwareCapabilitesVocabulary .


###  https://cyberterrain.org/ns/stone#operatingSystemRefs
stone:operatingSystemRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to software SCOs describing the operating systems this malware targets or runs on. (STIX: operating_system_refs)" ;
    rdfs:domain stone:Malware ;
    rdfs:range stone:SoftwareObject .


###  https://cyberterrain.org/ns/stone#sampleRefs
stone:sampleRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to file or artifact SCOs that are samples of this malware. (STIX: sample_refs)" ;
    rdfs:domain stone:Malware ;
    rdfs:range stone:StixCyberobservableObject .


#################################################################
#    SDO: malware-analysis
#################################################################

###  https://cyberterrain.org/ns/stone#result
stone:result rdf:type owl:ObjectProperty ;
    rdfs:comment "Analysis verdict for this malware analysis (malware-result-ov): malicious, suspicious, benign, unknown. (STIX: result)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range stone:MalwareResultVocabulary .


###  https://cyberterrain.org/ns/stone#hostVmRef
stone:hostVmRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the software SCO describing the virtual machine used for analysis. (STIX: host_vm_ref)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range stone:SoftwareObject .


###  https://cyberterrain.org/ns/stone#operatingSystemRef
stone:operatingSystemRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the software SCO describing the operating system used for analysis. (STIX: operating_system_ref)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range stone:SoftwareObject .


###  https://cyberterrain.org/ns/stone#installedSoftwareRefs
stone:installedSoftwareRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to software SCOs installed in the analysis environment. (STIX: installed_software_refs)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range stone:SoftwareObject .


###  https://cyberterrain.org/ns/stone#analysisScoRefs
stone:analysisScoRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to SCOs generated or observed as a result of this analysis. (STIX: analysis_sco_refs)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range stone:StixCyberobservableObject .


#################################################################
#    SDO: opinion
#################################################################

###  https://cyberterrain.org/ns/stone#opinion
stone:opinion rdf:type owl:ObjectProperty ;
    rdfs:comment "Level of agreement expressed by this opinion (opinion-enum): strongly-disagree, disagree, neutral, agree, strongly-agree. (STIX: opinion)" ;
    rdfs:domain stone:Opinion ;
    rdfs:range stone:OpinionEnumeration .


#################################################################
#    SDO: report
#################################################################

###  https://cyberterrain.org/ns/stone#reportTypes
stone:reportTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "Categories of intelligence covered by this report (report-type-ov). Multiple values as multiple triples. (STIX: report_types)" ;
    rdfs:domain stone:Report ;
    rdfs:range stone:ReportTypeVocabulary .


#################################################################
#    SDO: threat-actor
#################################################################

###  https://cyberterrain.org/ns/stone#threatActorTypes
stone:threatActorTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "Categories of this threat actor (threat-actor-type-ov). Multiple values as multiple triples. (STIX: threat_actor_types)" ;
    rdfs:domain stone:ThreatActor ;
    rdfs:range stone:ThreatActorTypeVocabulary .


###  https://cyberterrain.org/ns/stone#threatActorRoles
stone:threatActorRoles rdf:type owl:ObjectProperty ;
    rdfs:comment "Roles this threat actor plays in an attack (threat-actor-role-ov): agent, director, independent, infrastructure-architect, infrastructure-operator, malware-author, sponsor. (STIX: roles)" ;
    rdfs:domain stone:ThreatActor ;
    rdfs:range stone:ThreatActorRoleVocabulary .


###  https://cyberterrain.org/ns/stone#sophistication
stone:sophistication rdf:type owl:ObjectProperty ;
    rdfs:comment "Skill and knowledge level of this threat actor (threat-actor-sophistication-ov): none, minimal, intermediate, advanced, expert, innovator, strategic. (STIX: sophistication)" ;
    rdfs:domain stone:ThreatActor ;
    rdfs:range stone:ThreatActorSophisticationVocabulary .


###  https://cyberterrain.org/ns/stone#personalMotivations
stone:personalMotivations rdf:type owl:ObjectProperty ;
    rdfs:comment "Personal motivations of this threat actor, distinct from organisational motivations (attack-motivation-ov). Multiple values as multiple triples. (STIX: personal_motivations)" ;
    rdfs:domain stone:ThreatActor ;
    rdfs:range stone:AttackMotivationVocabulary .


#################################################################
#    SDO: tool
#################################################################

###  https://cyberterrain.org/ns/stone#toolTypes
stone:toolTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "Functional categories of this tool (tool-type-ov). Multiple values as multiple triples. (STIX: tool_types)" ;
    rdfs:domain stone:Tool ;
    rdfs:range stone:ToolTypeVocabulary .


#################################################################
#    SRO: relationship
#################################################################

###  https://cyberterrain.org/ns/stone#sourceRef
stone:sourceRef rdf:type owl:ObjectProperty ;
    rdfs:comment "The STIX Core Object at the source (start) of this relationship. (STIX: source_ref)" ;
    rdfs:domain stone:Relationship ;
    rdfs:range stone:StixCoreObject .


###  https://cyberterrain.org/ns/stone#targetRef
stone:targetRef rdf:type owl:ObjectProperty ;
    rdfs:comment "The STIX Core Object at the target (end) of this relationship. (STIX: target_ref)" ;
    rdfs:domain stone:Relationship ;
    rdfs:range stone:StixCoreObject .


#################################################################
#    SRO: sighting
#################################################################

###  https://cyberterrain.org/ns/stone#sightingOfRef
stone:sightingOfRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the STIX Core Object that was sighted. Typically an indicator, malware, campaign, threat-actor, intrusion-set, tool, attack-pattern, or infrastructure. (STIX: sighting_of_ref)" ;
    rdfs:domain stone:Sighting ;
    rdfs:range stone:StixCoreObject .


###  https://cyberterrain.org/ns/stone#observedDataRefs
stone:observedDataRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to ObservedData SDOs that provide evidence supporting this sighting. (STIX: observed_data_refs)" ;
    rdfs:domain stone:Sighting ;
    rdfs:range stone:ObservedData .


###  https://cyberterrain.org/ns/stone#whereSightedRefs
stone:whereSightedRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to Identity SDOs representing where or by whom the sighting was recorded. (STIX: where_sighted_refs)" ;
    rdfs:domain stone:Sighting ;
    rdfs:range stone:Identity .


#################################################################
#    Meta: language-content
#################################################################

###  https://cyberterrain.org/ns/stone#objectRef
stone:objectRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the STIX object whose string properties are being translated by this language-content object. (STIX: object_ref)" ;
    rdfs:domain stone:LanguageContentObject ;
    rdfs:range stone:StixObject .


#################################################################
#    Meta: extension-definition
#################################################################

###  https://cyberterrain.org/ns/stone#extensionTypes
stone:extensionTypes rdf:type owl:ObjectProperty ;
    rdfs:comment "How this extension definition is used (extension-types-enum): new-sdo, new-sco, new-sro, property-extension, toplevel-property-extension. Multiple values as multiple triples. (STIX: extension_types)" ;
    rdfs:domain stone:ExtensionDefinitionObject ;
    rdfs:range stone:ExtensionTypesEnumeration .


#################################################################
#    Bundle
#################################################################

###  https://cyberterrain.org/ns/stone#objects
stone:objects rdf:type owl:ObjectProperty ;
    rdfs:comment "STIX objects (SDOs, SCOs, SROs, meta-objects) carried in this bundle. (STIX: objects)" ;
    rdfs:domain stone:StixBundle ;
    rdfs:range stone:StixObject .


#################################################################
#    SCO: directory
#################################################################

###  https://cyberterrain.org/ns/stone#containsRefs
stone:containsRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to file or directory SCOs contained within this directory or archive. (STIX: contains_refs)" ;
    rdfs:range stone:StixCyberobservableObject .


#################################################################
#    SCO: domain-name, ipv4-addr, ipv6-addr
#################################################################

###  https://cyberterrain.org/ns/stone#resolvesToRefs
stone:resolvesToRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "For domain-name: references to ipv4-addr, ipv6-addr, or domain-name SCOs this domain resolves to. For ipv4-addr / ipv6-addr: references to mac-addr SCOs. (STIX: resolves_to_refs)" ;
    rdfs:range stone:StixCyberobservableObject .


###  https://cyberterrain.org/ns/stone#belongsToRefs
stone:belongsToRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to autonomous-system SCOs that own this IP address. (STIX: belongs_to_refs)" ;
    rdfs:range stone:AutonomousSystemObject .


#################################################################
#    SCO: email-addr
#################################################################

###  https://cyberterrain.org/ns/stone#belongsToRef
stone:belongsToRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the user-account SCO that owns this email address. (STIX: belongs_to_ref)" ;
    rdfs:domain stone:EmailAddressObject ;
    rdfs:range stone:UserAccountObject .


#################################################################
#    SCO: email-message
#################################################################

###  https://cyberterrain.org/ns/stone#fromRef
stone:fromRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the email-addr SCO in the From: header. (STIX: from_ref)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:EmailAddressObject .


###  https://cyberterrain.org/ns/stone#senderRef
stone:senderRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the email-addr SCO in the Sender: header. (STIX: sender_ref)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:EmailAddressObject .


###  https://cyberterrain.org/ns/stone#toRefs
stone:toRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to email-addr SCOs in the To: header. (STIX: to_refs)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:EmailAddressObject .


###  https://cyberterrain.org/ns/stone#ccRefs
stone:ccRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to email-addr SCOs in the Cc: header. (STIX: cc_refs)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:EmailAddressObject .


###  https://cyberterrain.org/ns/stone#bccRefs
stone:bccRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to email-addr SCOs in the Bcc: header. (STIX: bcc_refs)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:EmailAddressObject .


###  https://cyberterrain.org/ns/stone#rawEmailRef
stone:rawEmailRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the artifact SCO containing the full raw email bytes. (STIX: raw_email_ref)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:ArtifactObject .


###  https://cyberterrain.org/ns/stone#bodyMultipart
stone:bodyMultipart rdf:type owl:ObjectProperty ;
    rdfs:comment "MIME parts of a multipart email message. Each part is a stone:EmailMimePart individual. (STIX: body_multipart)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range stone:EmailMimePart .


###  https://cyberterrain.org/ns/stone#bodyRawRef
stone:bodyRawRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to an artifact or file SCO containing the raw bytes of this MIME part. (STIX: body_raw_ref)" ;
    rdfs:domain stone:EmailMimePart ;
    rdfs:range stone:StixCyberobservableObject .


#################################################################
#    SCO: file
#################################################################

###  https://cyberterrain.org/ns/stone#parentDirectoryRef
stone:parentDirectoryRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the directory SCO that contains this file. (STIX: parent_directory_ref)" ;
    rdfs:domain stone:FileObject ;
    rdfs:range stone:DirectoryObject .


###  https://cyberterrain.org/ns/stone#contentRef
stone:contentRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the artifact SCO that holds the content of this file. (STIX: content_ref)" ;
    rdfs:domain stone:FileObject ;
    rdfs:range stone:ArtifactObject .


#################################################################
#    SCO: network-traffic
#################################################################

###  https://cyberterrain.org/ns/stone#srcRef
stone:srcRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the source address SCO for this network traffic flow (ipv4-addr, ipv6-addr, mac-addr, or domain-name). (STIX: src_ref)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range stone:StixCyberobservableObject .


###  https://cyberterrain.org/ns/stone#dstRef
stone:dstRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the destination address SCO for this network traffic flow. (STIX: dst_ref)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range stone:StixCyberobservableObject .


###  https://cyberterrain.org/ns/stone#srcPayloadRef
stone:srcPayloadRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the artifact SCO containing the source-to-destination payload bytes. (STIX: src_payload_ref)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range stone:ArtifactObject .


###  https://cyberterrain.org/ns/stone#dstPayloadRef
stone:dstPayloadRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the artifact SCO containing the destination-to-source payload bytes. (STIX: dst_payload_ref)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range stone:ArtifactObject .


###  https://cyberterrain.org/ns/stone#encapsulatesRefs
stone:encapsulatesRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to network-traffic SCOs encapsulated within this flow (e.g., inner tunnelled protocols). (STIX: encapsulates_refs)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range stone:NetworkTrafficObject .


###  https://cyberterrain.org/ns/stone#encapsulatedByRef
stone:encapsulatedByRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the network-traffic SCO that encapsulates (wraps) this flow. (STIX: encapsulated_by_ref)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range stone:NetworkTrafficObject .


#################################################################
#    SCO: process
#################################################################

###  https://cyberterrain.org/ns/stone#openedConnectionRefs
stone:openedConnectionRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to network-traffic SCOs representing connections this process has opened. (STIX: opened_connection_refs)" ;
    rdfs:domain stone:ProcessObject ;
    rdfs:range stone:NetworkTrafficObject .


###  https://cyberterrain.org/ns/stone#creatorUserRef
stone:creatorUserRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the user-account SCO of the user who created this process or registry key. (STIX: creator_user_ref)" ;
    rdfs:range stone:UserAccountObject .


###  https://cyberterrain.org/ns/stone#imageRef
stone:imageRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the file SCO of the executable image that was launched to create this process. (STIX: image_ref)" ;
    rdfs:domain stone:ProcessObject ;
    rdfs:range stone:FileObject .


###  https://cyberterrain.org/ns/stone#parentRef
stone:parentRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the parent process SCO of this process. (STIX: parent_ref)" ;
    rdfs:domain stone:ProcessObject ;
    rdfs:range stone:ProcessObject .


###  https://cyberterrain.org/ns/stone#childRefs
stone:childRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to child process SCOs spawned by this process. (STIX: child_refs)" ;
    rdfs:domain stone:ProcessObject ;
    rdfs:range stone:ProcessObject .


#################################################################
#    SCO: user-account
#################################################################

###  https://cyberterrain.org/ns/stone#accountType
stone:accountType rdf:type owl:ObjectProperty ;
    rdfs:comment "Type of user account (account-type-ov): facebook, ldap, nis, openid, radius, skype, tacacs, twitter, unix, windows-domain, windows-local. (STIX: account_type)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range stone:AccountTypeVocabulary .


#################################################################
#    SCO: windows-registry-key
#################################################################

###  https://cyberterrain.org/ns/stone#values
stone:values rdf:type owl:ObjectProperty ;
    rdfs:comment "Windows registry value entries under this key. Each entry is a stone:WindowsRegistryValue individual. (STIX: values)" ;
    rdfs:domain stone:WindowsRegistryKetObject ;
    rdfs:range stone:WindowsRegistryValue .


#################################################################
#    Sub-Object: WindowsRegistryValue
#################################################################

###  https://cyberterrain.org/ns/stone#dataType
stone:dataType rdf:type owl:ObjectProperty ;
    rdfs:comment "Data type of this Windows registry value (windows-registry-datatype-enum): REG_NONE, REG_SZ, REG_EXPAND_SZ, REG_BINARY, REG_DWORD, etc. (STIX: data_type)" ;
    rdfs:domain stone:WindowsRegistryValue ;
    rdfs:range stone:WindowsRegistryDatatypeEnumeration .


#################################################################
#    SCO: x509-certificate
#################################################################

###  https://cyberterrain.org/ns/stone#x509V3Extensions
stone:x509V3Extensions rdf:type owl:ObjectProperty ;
    rdfs:comment "X.509 v3 extension fields for this certificate. (STIX: x509_v3_extensions)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range stone:X509V3Extensions .


#################################################################
#    Extension: artifact
#################################################################

###  https://cyberterrain.org/ns/stone#encryptionAlgorithm
stone:encryptionAlgorithm rdf:type owl:ObjectProperty ;
    rdfs:comment "Encryption algorithm applied to this artifact (encryption-algorithm-enum). Required when decryptionKey is present. (STIX: encryption_algorithm)" ;
    rdfs:domain stone:ArtifactObject ;
    rdfs:range stone:EncryptionAlgorithmEnumeration .


#################################################################
#    Extension: windows-pebinary-ext
#################################################################

###  https://cyberterrain.org/ns/stone#peType
stone:peType rdf:type owl:ObjectProperty ;
    rdfs:comment "PE binary subtype (windows-pebinary-type-ov): exe, dll, or sys. (STIX: pe_type)" ;
    rdfs:range stone:WindowsPEBinaryVocabulary .


###  https://cyberterrain.org/ns/stone#fileHeaderHashes
stone:fileHeaderHashes rdf:type owl:ObjectProperty ;
    rdfs:comment "Hashes of the PE file header, expressed as HashEntry individuals. (STIX: file_header_hashes)" ;
    rdfs:range stone:HashEntry .


###  https://cyberterrain.org/ns/stone#sections
stone:sections rdf:type owl:ObjectProperty ;
    rdfs:comment "PE section entries for this binary. Each entry is a stone:WindowsPeSection individual. (STIX: sections)" ;
    rdfs:range stone:WindowsPeSection .


#################################################################
#    Extension: ntfs-ext
#################################################################

###  https://cyberterrain.org/ns/stone#alternateDataStreams
stone:alternateDataStreams rdf:type owl:ObjectProperty ;
    rdfs:comment "NTFS Alternate Data Streams present on this file. Each entry is a stone:AlternateDataStream individual. (STIX: alternate_data_streams)" ;
    rdfs:range stone:AlternateDataStream .


#################################################################
#    Extension: socket-ext
#################################################################

###  https://cyberterrain.org/ns/stone#addressFamily
stone:addressFamily rdf:type owl:ObjectProperty ;
    rdfs:comment "Address family of this socket (network-socket-address-family-enum): AF_UNSPEC, AF_INET, AF_INET6, AF_IPX, AF_APPLETALK, AF_NETBIOS, AF_IRDA, AF_BTH. (STIX: address_family)" ;
    rdfs:range stone:NetworkSocketAddressFamilyEnumeration .


###  https://cyberterrain.org/ns/stone#socketType
stone:socketType rdf:type owl:ObjectProperty ;
    rdfs:comment "Type of this socket (network-socket-type-enum): SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, SOCK_RDM, SOCK_SEQPACKET. (STIX: socket_type)" ;
    rdfs:range stone:NetworkSocketTypeEnumeration .


#################################################################
#    Extension: windows-process-ext
#################################################################

###  https://cyberterrain.org/ns/stone#integrityLevel
stone:integrityLevel rdf:type owl:ObjectProperty ;
    rdfs:comment "Windows integrity level of this process (windows-integrity-level-enum): low, medium, high, system. (STIX: integrity_level)" ;
    rdfs:range stone:WindowsIntegrityLevelEnumeration .


#################################################################
#    Extension: windows-service-ext
#################################################################

###  https://cyberterrain.org/ns/stone#startType
stone:startType rdf:type owl:ObjectProperty ;
    rdfs:comment "Service start type (windows-service-start-type-enum): SERVICE_AUTO_START, SERVICE_BOOT_START, SERVICE_DEMAND_START, SERVICE_DISABLED, SERVICE_SYSTEM_ALERT. (STIX: start_type)" ;
    rdfs:range stone:WindowsServiceStartTypeEnumeration .


###  https://cyberterrain.org/ns/stone#serviceType
stone:serviceType rdf:type owl:ObjectProperty ;
    rdfs:comment "Windows service type (windows-service-type-enum): SERVICE_KERNEL_DRIVER, SERVICE_FILE_SYSTEM_DRIVER, SERVICE_WIN32_OWN_PROCESS, SERVICE_WIN32_SHARE_PROCESS. (STIX: service_type)" ;
    rdfs:range stone:WindowsServiceTypeEnumeration .


###  https://cyberterrain.org/ns/stone#serviceStatus
stone:serviceStatus rdf:type owl:ObjectProperty ;
    rdfs:comment "Current status of this Windows service (windows-service-status-enum): SERVICE_RUNNING, SERVICE_STOPPED, SERVICE_PAUSED, etc. (STIX: service_status)" ;
    rdfs:range stone:WindowsServiceStatusEnumeration .


###  https://cyberterrain.org/ns/stone#serviceDllRefs
stone:serviceDllRefs rdf:type owl:ObjectProperty ;
    rdfs:comment "References to file SCOs for DLLs loaded by this Windows service. (STIX: service_dll_refs)" ;
    rdfs:range stone:FileObject .


#################################################################
#    Extension: http-request-ext
#################################################################

###  https://cyberterrain.org/ns/stone#messageBodyRef
stone:messageBodyRef rdf:type owl:ObjectProperty ;
    rdfs:comment "Reference to the artifact SCO containing the HTTP message body. (STIX: http-request-ext.message_body_ref)" ;
    rdfs:range stone:ArtifactObject .
