stone:subjectPublicKeyModulus rdf:type owl:DatatypeProperty ;
    rdfs:comment "RSA modulus of the subject's public key as a hex string. (STIX: subject_public_key_modulus)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#subjectPublicKeyExponent
stone:subjectPublicKeyExponent rdf:type owl:DatatypeProperty ;
    rdfs:comment "RSA public exponent of the subject's public key. (STIX: subject_public_key_exponent)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:integer .


