stone:canEscalatePrivs rdf:type owl:DatatypeProperty ;
    skos:definition "True if this account can escalate its own privileges." ;
    rdfs:comment "(STIX: can_escalate_privs)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:boolean .


###  https://cyberterrain.org/ns/stone#isDisabled
stone:isDisabled rdf:type owl:DatatypeProperty ;
    skos:definition "True if this account is currently disabled." ;
    rdfs:comment "(STIX: is_disabled)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:boolean .


###  https://cyberterrain.org/ns/stone#accountCreated
stone:accountCreated rdf:type owl:DatatypeProperty ;
    skos:definition "Timestamp when this account was created." ;
    rdfs:comment "(STIX: account_created)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#accountExpires
stone:accountExpires rdf:type owl:DatatypeProperty ;
    skos:definition "Timestamp when this account expires." ;
    rdfs:comment "(STIX: account_expires)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#credentialLastChanged
stone:credentialLastChanged rdf:type owl:DatatypeProperty ;
    skos:definition "Timestamp when the account credentials were last changed." ;
    rdfs:comment "(STIX: credential_last_changed)" ;
    rdfs:domain stone:UserAccountObject ;
