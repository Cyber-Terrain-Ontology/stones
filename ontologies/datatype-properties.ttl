#################################################################

###  https://cyberterrain.org/ns/stone#isMultipart
stone:isMultipart rdf:type owl:DatatypeProperty ;
    skos:definition "True if this email uses multipart MIME (bodyMultipart is populated); false if body contains the single plain-text body." ;
    rdfs:comment "(STIX: is_multipart)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:boolean .


###  https://cyberterrain.org/ns/stone#date
stone:date rdf:type owl:DatatypeProperty ;
    skos:definition "Date and time the email was sent as recorded in the Date header." ;
    rdfs:comment "(STIX: date)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#messageId
stone:messageId rdf:type owl:DatatypeProperty ;
    skos:definition "Value of the Message-ID header." ;
    rdfs:comment "(STIX: message_id)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#receivedLines
stone:receivedLines rdf:type owl:DatatypeProperty ;
    skos:definition "Received: header values in the order received. Multiple values as multiple triples." ;
    rdfs:comment "(STIX: received_lines)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#contentDisposition
stone:contentDisposition rdf:type owl:DatatypeProperty ;
    skos:definition "Content-Disposition header value for an email MIME part." ;
    rdfs:comment "(STIX: content_disposition)" ;
    rdfs:domain stone:EmailMimePart ;
    rdfs:range xsd:string .


#################################################################
#    SCO: file
#################################################################

###  https://cyberterrain.org/ns/stone#nameEnc
stone:nameEnc rdf:type owl:DatatypeProperty ;
