stone:subjectPublicKeyAlgorithm rdf:type owl:DatatypeProperty ;
    skos:definition "Algorithm of the subject's public key, e.g. 'rsaEncryption'." ;
    rdfs:comment "(STIX: subject_public_key_algorithm)" ;
