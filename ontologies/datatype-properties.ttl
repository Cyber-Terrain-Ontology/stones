# @prefix : <https://cyberterrain.org/ns/datatype-properties#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix stone: <https://cyberterrain.org/ns/stone#> .

<https://cyberterrain.org/ns/datatype-properties#> rdf:type owl:Ontology ;
    rdfs:comment "STIX 2.1 datatype properties for the STONE ontology. Property names use lowerCamelCase; the original snake_case STIX property name is noted in rdfs:comment where disambiguation is needed." .


#################################################################
#    Common Properties — all STIX Objects
#################################################################

###  https://cyberterrain.org/ns/stone#stixId
stone:stixId rdf:type owl:DatatypeProperty ;
    rdfs:comment "The STIX identifier string in the format <type>--<UUIDv4>. The IRI of the individual is the canonical identity; this property retains the string for JSON round-tripping and SPARQL querying. (STIX: id)" ;
    rdfs:domain stone:StixObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#stixType
stone:stixType rdf:type owl:DatatypeProperty ;
    rdfs:comment "The STIX object type string (e.g., 'attack-pattern'). Semantically redundant with rdf:type but preserved for JSON round-tripping. (STIX: type)" ;
    rdfs:domain stone:StixObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#specVersion
stone:specVersion rdf:type owl:DatatypeProperty ;
    rdfs:comment "STIX specification version. MUST be '2.1'. (STIX: spec_version)" ;
    rdfs:domain stone:StixObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#created
stone:created rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this object was created. (STIX: created)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#modified
stone:modified rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this object was last modified. MUST be >= created. (STIX: modified)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#revoked
stone:revoked rdf:type owl:DatatypeProperty ;
    rdfs:comment "If true, this object has been revoked and should no longer be considered accurate. (STIX: revoked)" ;
    rdfs:domain stone:StixObject ;
    rdfs:range xsd:boolean .


###  https://cyberterrain.org/ns/stone#labels
stone:labels rdf:type owl:DatatypeProperty ;
    rdfs:comment "Free-form string terms applying to this object. Multiple labels are expressed as multiple triples. (STIX: labels)" ;
    rdfs:domain stone:StixObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#confidence
stone:confidence rdf:type owl:DatatypeProperty ;
    rdfs:comment "Producer's confidence in the accuracy of this data, from 0 (no confidence) to 100 (fully confident). (STIX: confidence)" ;
    rdfs:domain stone:StixObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#lang
stone:lang rdf:type owl:DatatypeProperty ;
    rdfs:comment "BCP 47 language tag for the human-readable content of this object (e.g., 'en', 'fr'). Also used in GranularMarking. (STIX: lang)" ;
    rdfs:range xsd:string .


#################################################################
#    Widely-Shared Properties — SDOs, SCOs, and Sub-Objects
#################################################################

###  https://cyberterrain.org/ns/stone#name
stone:name rdf:type owl:DatatypeProperty ;
    rdfs:comment "Human-readable name. Used across SDOs, SCOs, and sub-objects. (STIX: name)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#description
stone:description rdf:type owl:DatatypeProperty ;
    rdfs:comment "Human-readable description providing additional detail. (STIX: description)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#aliases
stone:aliases rdf:type owl:DatatypeProperty ;
    rdfs:comment "Alternative names for this object. Multiple aliases are expressed as multiple triples. (STIX: aliases)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#firstSeen
stone:firstSeen rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this object was first observed or seen. (STIX: first_seen)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#lastSeen
stone:lastSeen rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this object was last observed or seen. MUST be >= firstSeen. (STIX: last_seen)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#version
stone:version rdf:type owl:DatatypeProperty ;
    rdfs:comment "Version string. Used for analysis tool version (malware-analysis), schema version (extension-definition), software version, X.509 version, and PDF format version. (STIX: version)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#goals
stone:goals rdf:type owl:DatatypeProperty ;
    rdfs:comment "High-level goals of this intrusion set or threat actor (e.g., 'financial gain'). Multiple values are expressed as multiple triples. (STIX: goals)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#authors
stone:authors rdf:type owl:DatatypeProperty ;
    rdfs:comment "Names of the authors of a note or opinion. Multiple values are expressed as multiple triples. (STIX: authors)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#url
stone:url rdf:type owl:DatatypeProperty ;
    rdfs:comment "URL to a referenced resource (external-reference) or the location of artifact content. (STIX: url)" ;
    rdfs:range xsd:anyURI .


###  https://cyberterrain.org/ns/stone#mimeType
stone:mimeType rdf:type owl:DatatypeProperty ;
    rdfs:comment "IANA MIME type of the content (artifact, file). (STIX: mime_type)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#displayName
stone:displayName rdf:type owl:DatatypeProperty ;
    rdfs:comment "Human-readable display name (email-addr, user-account, windows-service-ext). (STIX: display_name)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#value
stone:value rdf:type owl:DatatypeProperty ;
    rdfs:comment "Primary string value of an observable: the domain name, email address, IP address, MAC address, or URL. (STIX: value)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#ctime
stone:ctime rdf:type owl:DatatypeProperty ;
    rdfs:comment "Creation timestamp of a file system object. (STIX: ctime)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#mtime
stone:mtime rdf:type owl:DatatypeProperty ;
    rdfs:comment "Last-modified timestamp of a file system object. (STIX: mtime)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#atime
stone:atime rdf:type owl:DatatypeProperty ;
    rdfs:comment "Last-accessed timestamp of a file system object. (STIX: atime)" ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#path
stone:path rdf:type owl:DatatypeProperty ;
    rdfs:comment "Absolute file system path (directory, file). (STIX: path)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#pathEnc
stone:pathEnc rdf:type owl:DatatypeProperty ;
    rdfs:comment "Character encoding used for the path property when the path contains non-ASCII characters. (STIX: path_enc)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#size
stone:size rdf:type owl:DatatypeProperty ;
    rdfs:comment "Size in bytes (file, windows-pe-section, alternate-data-stream). (STIX: size)" ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#body
stone:body rdf:type owl:DatatypeProperty ;
    rdfs:comment "Plain-text body of an email message or a MIME part. (STIX: body)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#contentType
stone:contentType rdf:type owl:DatatypeProperty ;
    rdfs:comment "Value of the Content-Type header (email-message, email mime part). (STIX: content_type)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#subject
stone:subject rdf:type owl:DatatypeProperty ;
    rdfs:comment "Subject line of an email message, or Distinguished Name of the certificate subject. (STIX: subject)" ;
    rdfs:range xsd:string .


#################################################################
#    SDO: campaign
#################################################################

###  https://cyberterrain.org/ns/stone#objective
stone:objective rdf:type owl:DatatypeProperty ;
    rdfs:comment "Primary goal or objective of the campaign. (STIX: objective)" ;
    rdfs:domain stone:Campaign ;
    rdfs:range xsd:string .


#################################################################
#    SDO: identity
#################################################################

###  https://cyberterrain.org/ns/stone#roles
stone:roles rdf:type owl:DatatypeProperty ;
    rdfs:comment "Free-form roles this identity plays (e.g., 'analyst'). For threat-actor roles see the object property stone:threatActorRoles. (STIX: roles)" ;
    rdfs:domain stone:Identity ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#contactInformation
stone:contactInformation rdf:type owl:DatatypeProperty ;
    rdfs:comment "Contact details such as email address or phone number. (STIX: contact_information)" ;
    rdfs:domain stone:Identity ;
    rdfs:range xsd:string .


#################################################################
#    SDO: indicator
#################################################################

###  https://cyberterrain.org/ns/stone#pattern
stone:pattern rdf:type owl:DatatypeProperty ;
    rdfs:comment "Detection pattern expression (e.g., STIX patterning language). (STIX: pattern)" ;
    rdfs:domain stone:Indicator ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#patternVersion
stone:patternVersion rdf:type owl:DatatypeProperty ;
    rdfs:comment "Version of the pattern language (e.g., STIX patterning language version). (STIX: pattern_version)" ;
    rdfs:domain stone:Indicator ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#validFrom
stone:validFrom rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp from which this indicator is considered valid. (STIX: valid_from)" ;
    rdfs:domain stone:Indicator ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#validUntil
stone:validUntil rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp after which this indicator is no longer valid. (STIX: valid_until)" ;
    rdfs:domain stone:Indicator ;
    rdfs:range xsd:dateTime .


#################################################################
#    SDO: location
#################################################################

###  https://cyberterrain.org/ns/stone#latitude
stone:latitude rdf:type owl:DatatypeProperty ;
    rdfs:comment "Latitude in decimal degrees, range -90 to 90. Required when longitude is present. (STIX: latitude)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:float .


###  https://cyberterrain.org/ns/stone#longitude
stone:longitude rdf:type owl:DatatypeProperty ;
    rdfs:comment "Longitude in decimal degrees, range -180 to 180. Required when latitude is present. (STIX: longitude)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:float .


###  https://cyberterrain.org/ns/stone#precision
stone:precision rdf:type owl:DatatypeProperty ;
    rdfs:comment "Radius of accuracy in metres around the latitude/longitude point. (STIX: precision)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:float .


###  https://cyberterrain.org/ns/stone#country
stone:country rdf:type owl:DatatypeProperty ;
    rdfs:comment "ISO 3166-1 alpha-2 country code (e.g., 'US', 'GB'). (STIX: country)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#administrativeArea
stone:administrativeArea rdf:type owl:DatatypeProperty ;
    rdfs:comment "State, province, or region within a country. (STIX: administrative_area)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#city
stone:city rdf:type owl:DatatypeProperty ;
    rdfs:comment "City name. (STIX: city)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#streetAddress
stone:streetAddress rdf:type owl:DatatypeProperty ;
    rdfs:comment "Street address. (STIX: street_address)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#postalCode
stone:postalCode rdf:type owl:DatatypeProperty ;
    rdfs:comment "Postal or ZIP code. (STIX: postal_code)" ;
    rdfs:domain stone:Location ;
    rdfs:range xsd:string .


#################################################################
#    SDO: malware
#################################################################

###  https://cyberterrain.org/ns/stone#isFamily
stone:isFamily rdf:type owl:DatatypeProperty ;
    rdfs:comment "True if this represents a malware family; false for a specific instance or sample. (STIX: is_family)" ;
    rdfs:domain stone:Malware ;
    rdfs:range xsd:boolean .


#################################################################
#    SDO: malware-analysis
#################################################################

###  https://cyberterrain.org/ns/stone#product
stone:product rdf:type owl:DatatypeProperty ;
    rdfs:comment "Name of the analysis tool used (e.g., 'Cuckoo', 'VirusTotal'). (STIX: product)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#configurationVersion
stone:configurationVersion rdf:type owl:DatatypeProperty ;
    rdfs:comment "Version of the analysis tool configuration. (STIX: configuration_version)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#modules
stone:modules rdf:type owl:DatatypeProperty ;
    rdfs:comment "Names of analysis modules or plugins used. Multiple values as multiple triples. (STIX: modules)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#analysisEngineVersion
stone:analysisEngineVersion rdf:type owl:DatatypeProperty ;
    rdfs:comment "Version of the analysis engine. (STIX: analysis_engine_version)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#analysisDefinitionVersion
stone:analysisDefinitionVersion rdf:type owl:DatatypeProperty ;
    rdfs:comment "Version of the analysis definitions or signatures. (STIX: analysis_definition_version)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#submitted
stone:submitted rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when the sample was submitted for analysis. (STIX: submitted)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#analysisStarted
stone:analysisStarted rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when analysis began. (STIX: analysis_started)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#analysisEnded
stone:analysisEnded rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when analysis concluded. (STIX: analysis_ended)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#avResult
stone:avResult rdf:type owl:DatatypeProperty ;
    rdfs:comment "Raw classification string from an antivirus engine (e.g., 'Trojan.GenericKD'). (STIX: av_result)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#resultName
stone:resultName rdf:type owl:DatatypeProperty ;
    rdfs:comment "Classification name from the analysis product. (STIX: result_name)" ;
    rdfs:domain stone:MalwareAnalysis ;
    rdfs:range xsd:string .


#################################################################
#    SDO: note
#################################################################

###  https://cyberterrain.org/ns/stone#abstract
stone:abstract rdf:type owl:DatatypeProperty ;
    rdfs:comment "Brief summary of the note. (STIX: abstract)" ;
    rdfs:domain stone:Note ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#content
stone:content rdf:type owl:DatatypeProperty ;
    rdfs:comment "Full body text of the note. (STIX: content)" ;
    rdfs:domain stone:Note ;
    rdfs:range xsd:string .


#################################################################
#    SDO: observed-data
#################################################################

###  https://cyberterrain.org/ns/stone#firstObserved
stone:firstObserved rdf:type owl:DatatypeProperty ;
    rdfs:comment "Earliest timestamp at which this observation occurred. (STIX: first_observed)" ;
    rdfs:domain stone:ObservedData ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#lastObserved
stone:lastObserved rdf:type owl:DatatypeProperty ;
    rdfs:comment "Latest timestamp at which this observation occurred. MUST be >= firstObserved. (STIX: last_observed)" ;
    rdfs:domain stone:ObservedData ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#numberObserved
stone:numberObserved rdf:type owl:DatatypeProperty ;
    rdfs:comment "Number of times the observation occurred. MUST be >= 1. (STIX: number_observed)" ;
    rdfs:domain stone:ObservedData ;
    rdfs:range xsd:integer .


#################################################################
#    SDO: opinion
#################################################################

###  https://cyberterrain.org/ns/stone#explanation
stone:explanation rdf:type owl:DatatypeProperty ;
    rdfs:comment "Explanation of why this opinion was formed. (STIX: explanation)" ;
    rdfs:domain stone:Opinion ;
    rdfs:range xsd:string .


#################################################################
#    SDO: report
#################################################################

###  https://cyberterrain.org/ns/stone#published
stone:published rdf:type owl:DatatypeProperty ;
    rdfs:comment "Date and time this report was published. (STIX: published)" ;
    rdfs:domain stone:Report ;
    rdfs:range xsd:dateTime .


#################################################################
#    SDO: tool
#################################################################

###  https://cyberterrain.org/ns/stone#toolVersion
stone:toolVersion rdf:type owl:DatatypeProperty ;
    rdfs:comment "Version string of the tool. (STIX: tool_version)" ;
    rdfs:domain stone:Tool ;
    rdfs:range xsd:string .


#################################################################
#    SRO: relationship
#################################################################

###  https://cyberterrain.org/ns/stone#relationshipType
stone:relationshipType rdf:type owl:DatatypeProperty ;
    rdfs:comment "Semantic type of this relationship (e.g., 'uses', 'targets', 'indicates'). (STIX: relationship_type)" ;
    rdfs:domain stone:Relationship ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#startTime
stone:startTime rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this relationship began. (STIX: start_time)" ;
    rdfs:domain stone:Relationship ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#stopTime
stone:stopTime rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this relationship ended. MUST be >= startTime. (STIX: stop_time)" ;
    rdfs:domain stone:Relationship ;
    rdfs:range xsd:dateTime .


#################################################################
#    SRO: sighting
#################################################################

###  https://cyberterrain.org/ns/stone#count
stone:count rdf:type owl:DatatypeProperty ;
    rdfs:comment "Number of times the sighted object was observed. MUST be >= 0. (STIX: count)" ;
    rdfs:domain stone:Sighting ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#summary
stone:summary rdf:type owl:DatatypeProperty ;
    rdfs:comment "If true, this sighting aggregates multiple observations rather than recording a single specific event. (STIX: summary)" ;
    rdfs:domain stone:Sighting ;
    rdfs:range xsd:boolean .


#################################################################
#    Meta: marking-definition
#################################################################

###  https://cyberterrain.org/ns/stone#definitionType
stone:definitionType rdf:type owl:DatatypeProperty ;
    rdfs:comment "Type of marking definition: 'tlp' or 'statement'. (STIX: definition_type)" ;
    rdfs:domain stone:MarkingDefinitionObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#tlp
stone:tlp rdf:type owl:DatatypeProperty ;
    rdfs:comment "TLP level for a TLP marking definition: 'white', 'green', 'amber', or 'red'. (STIX: definition.tlp)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#statement
stone:statement rdf:type owl:DatatypeProperty ;
    rdfs:comment "Human-readable statement for a statement marking definition (e.g., a copyright notice). (STIX: definition.statement)" ;
    rdfs:range xsd:string .


#################################################################
#    Meta: language-content
#################################################################

###  https://cyberterrain.org/ns/stone#objectModified
stone:objectModified rdf:type owl:DatatypeProperty ;
    rdfs:comment "The modified timestamp of the STIX object being translated. Used to pin a translation to a specific version. (STIX: object_modified)" ;
    rdfs:domain stone:LanguageContentObject ;
    rdfs:range xsd:dateTime .


#################################################################
#    Meta: extension-definition
#################################################################

###  https://cyberterrain.org/ns/stone#schema
stone:schema rdf:type owl:DatatypeProperty ;
    rdfs:comment "URL pointing to, or the raw content of, the JSON Schema defining this extension. (STIX: schema)" ;
    rdfs:domain stone:ExtensionDefinitionObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#extensionProperties
stone:extensionProperties rdf:type owl:DatatypeProperty ;
    rdfs:comment "Names of new top-level properties introduced by a toplevel-property-extension. Multiple values as multiple triples. (STIX: extension_properties)" ;
    rdfs:domain stone:ExtensionDefinitionObject ;
    rdfs:range xsd:string .


#################################################################
#    SCO: common
#################################################################

###  https://cyberterrain.org/ns/stone#defanged
stone:defanged rdf:type owl:DatatypeProperty ;
    rdfs:comment "If true, the observable has been defanged (e.g., '198[.]51[.]100[.]0' in place of '198.51.100.0'). (STIX: defanged)" ;
    rdfs:domain stone:StixCyberobservableObject ;
    rdfs:range xsd:boolean .


#################################################################
#    SCO: artifact
#################################################################

###  https://cyberterrain.org/ns/stone#payloadBin
stone:payloadBin rdf:type owl:DatatypeProperty ;
    rdfs:comment "Artifact byte content encoded as base64. Mutually exclusive with url. (STIX: payload_bin)" ;
    rdfs:domain stone:ArtifactObject ;
    rdfs:range xsd:base64Binary .


###  https://cyberterrain.org/ns/stone#decryptionKey
stone:decryptionKey rdf:type owl:DatatypeProperty ;
    rdfs:comment "Decryption key for this artifact when it is encrypted. (STIX: decryption_key)" ;
    rdfs:domain stone:ArtifactObject ;
    rdfs:range xsd:string .


#################################################################
#    SCO: autonomous-system
#################################################################

###  https://cyberterrain.org/ns/stone#number
stone:number rdf:type owl:DatatypeProperty ;
    rdfs:comment "Autonomous System number (ASN). (STIX: number)" ;
    rdfs:domain stone:AutonomousSystemObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#rir
stone:rir rdf:type owl:DatatypeProperty ;
    rdfs:comment "Regional Internet Registry that assigned this ASN (e.g., 'ARIN', 'RIPE'). (STIX: rir)" ;
    rdfs:domain stone:AutonomousSystemObject ;
    rdfs:range xsd:string .


#################################################################
#    SCO: email-message
#################################################################

###  https://cyberterrain.org/ns/stone#isMultipart
stone:isMultipart rdf:type owl:DatatypeProperty ;
    rdfs:comment "True if this email uses multipart MIME (bodyMultipart is populated); false if body contains the single plain-text body. (STIX: is_multipart)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:boolean .


###  https://cyberterrain.org/ns/stone#date
stone:date rdf:type owl:DatatypeProperty ;
    rdfs:comment "Date and time the email was sent as recorded in the Date header. (STIX: date)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#messageId
stone:messageId rdf:type owl:DatatypeProperty ;
    rdfs:comment "Value of the Message-ID header. (STIX: message_id)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#receivedLines
stone:receivedLines rdf:type owl:DatatypeProperty ;
    rdfs:comment "Received: header values in the order received. Multiple values as multiple triples. (STIX: received_lines)" ;
    rdfs:domain stone:EmailMessageObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#contentDisposition
stone:contentDisposition rdf:type owl:DatatypeProperty ;
    rdfs:comment "Content-Disposition header value for an email MIME part. (STIX: content_disposition)" ;
    rdfs:domain stone:EmailMimePart ;
    rdfs:range xsd:string .


#################################################################
#    SCO: file
#################################################################

###  https://cyberterrain.org/ns/stone#nameEnc
stone:nameEnc rdf:type owl:DatatypeProperty ;
    rdfs:comment "Character encoding of the file name when non-ASCII characters are present. (STIX: name_enc)" ;
    rdfs:domain stone:FileObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#magicNumberHex
stone:magicNumberHex rdf:type owl:DatatypeProperty ;
    rdfs:comment "Magic bytes (file signature) as a hex string. (STIX: magic_number_hex)" ;
    rdfs:domain stone:FileObject ;
    rdfs:range xsd:hexBinary .


#################################################################
#    SCO: network-traffic
#################################################################

###  https://cyberterrain.org/ns/stone#protocols
stone:protocols rdf:type owl:DatatypeProperty ;
    rdfs:comment "Ordered list of protocols from lowest to highest layer (e.g., 'ipv4', 'tcp', 'http'). Multiple values as multiple triples. (STIX: protocols)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#srcPort
stone:srcPort rdf:type owl:DatatypeProperty ;
    rdfs:comment "Source port number (0–65535). (STIX: src_port)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#dstPort
stone:dstPort rdf:type owl:DatatypeProperty ;
    rdfs:comment "Destination port number (0–65535). (STIX: dst_port)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#start
stone:start rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this network traffic flow started. (STIX: start)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#end
stone:end rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this network traffic flow ended. (STIX: end)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#isActive
stone:isActive rdf:type owl:DatatypeProperty ;
    rdfs:comment "True if this network traffic flow was still active when it was observed. (STIX: is_active)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:boolean .


###  https://cyberterrain.org/ns/stone#srcByteCount
stone:srcByteCount rdf:type owl:DatatypeProperty ;
    rdfs:comment "Total bytes sent from source to destination. (STIX: src_byte_count)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#dstByteCount
stone:dstByteCount rdf:type owl:DatatypeProperty ;
    rdfs:comment "Total bytes sent from destination to source. (STIX: dst_byte_count)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#srcPackets
stone:srcPackets rdf:type owl:DatatypeProperty ;
    rdfs:comment "Number of packets sent from source to destination. (STIX: src_packets)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#dstPackets
stone:dstPackets rdf:type owl:DatatypeProperty ;
    rdfs:comment "Number of packets sent from destination to source. (STIX: dst_packets)" ;
    rdfs:domain stone:NetworkTrafficObject ;
    rdfs:range xsd:integer .


