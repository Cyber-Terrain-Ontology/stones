###  https://cyberterrain.org/ns/stone#accountFirstLogin
stone:accountFirstLogin rdf:type owl:DatatypeProperty ;
    skos:definition "Timestamp of the first login for this account." ;
    rdfs:comment "(STIX: account_first_login)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#accountLastLogin
stone:accountLastLogin rdf:type owl:DatatypeProperty ;
    skos:definition "Timestamp of the most recent login for this account." ;
    rdfs:comment "(STIX: account_last_login)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


