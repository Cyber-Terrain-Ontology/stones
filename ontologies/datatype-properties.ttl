stone:signatureAlgorithm rdf:type owl:DatatypeProperty ;
    rdfs:comment "Algorithm used to sign this certificate (e.g., 'sha256WithRSAEncryption'). (STIX: signature_algorithm)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#issuer
stone:issuer rdf:type owl:DatatypeProperty ;
    rdfs:comment "Distinguished Name of the certificate issuer. (STIX: issuer)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#validityNotBefore
stone:validityNotBefore rdf:type owl:DatatypeProperty ;
    rdfs:comment "Start of the certificate validity period. (STIX: validity_not_before)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#validityNotAfter
stone:validityNotAfter rdf:type owl:DatatypeProperty ;
    rdfs:comment "End of the certificate validity period. (STIX: validity_not_after)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:dateTime .


