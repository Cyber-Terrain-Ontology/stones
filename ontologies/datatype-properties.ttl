stone:serialNumber rdf:type owl:DatatypeProperty ;
    rdfs:comment "Serial number assigned to this certificate by the issuer. (STIX: serial_number)" ;
    rdfs:domain stone:X509CertificateObject ;
    rdfs:range xsd:string .


