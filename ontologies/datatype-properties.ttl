stone:descriptions rdf:type owl:DatatypeProperty ;
    rdfs:comment "Description strings for a Windows service. Multiple values as multiple triples. (STIX: windows-service-ext.descriptions)" ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#groupName
stone:groupName rdf:type owl:DatatypeProperty ;
    rdfs:comment "Load ordering group for this Windows service. (STIX: windows-service-ext.group_name)" ;
    rdfs:range xsd:string .


#################################################################
#    Extension: unix-account-ext
#################################################################

###  https://cyberterrain.org/ns/stone#uid
stone:uid rdf:type owl:DatatypeProperty ;
    rdfs:comment "Numeric UNIX user ID (UID). (STIX: unix-account-ext.uid)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#gid
stone:gid rdf:type owl:DatatypeProperty ;
    rdfs:comment "Primary numeric UNIX group ID (GID). (STIX: unix-account-ext.gid)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:integer .


###  https://cyberterrain.org/ns/stone#groups
stone:groups rdf:type owl:DatatypeProperty ;
    rdfs:comment "Names of UNIX groups this account belongs to. Multiple values as multiple triples. (STIX: unix-account-ext.groups)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#homeDir
stone:homeDir rdf:type owl:DatatypeProperty ;
    rdfs:comment "Home directory path for this UNIX account. (STIX: unix-account-ext.home_dir)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:string .


###  https://cyberterrain.org/ns/stone#shell
stone:shell rdf:type owl:DatatypeProperty ;
    rdfs:comment "Login shell path for this UNIX account (e.g., '/bin/bash'). (STIX: unix-account-ext.shell)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:string .


