###  https://cyberterrain.org/ns/stone#vendor
stone:vendor rdf:type owl:DatatypeProperty ;
    skos:definition "Name of the software vendor." ;
    rdfs:comment "(STIX: vendor)" ;
    rdfs:domain stone:SoftwareObject ;
