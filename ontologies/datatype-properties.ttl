#################################################################

###  https://cyberterrain.org/ns/stone#isSelfSigned
stone:isSelfSigned rdf:type owl:DatatypeProperty ;
    rdfs:comment "True if this certificate is self-signed. (STIX: is_self_signed)" ;
    rdfs:domain stone:X509CertificateObject ;
