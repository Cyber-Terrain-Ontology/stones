stone:accountCreated rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this account was created. (STIX: account_created)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#accountExpires
stone:accountExpires rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when this account expires. (STIX: account_expires)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#credentialLastChanged
stone:credentialLastChanged rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp when the account credentials were last changed. (STIX: credential_last_changed)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#accountFirstLogin
stone:accountFirstLogin rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp of the first login for this account. (STIX: account_first_login)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


###  https://cyberterrain.org/ns/stone#accountLastLogin
stone:accountLastLogin rdf:type owl:DatatypeProperty ;
    rdfs:comment "Timestamp of the most recent login for this account. (STIX: account_last_login)" ;
    rdfs:domain stone:UserAccountObject ;
    rdfs:range xsd:dateTime .


